{
  "entities": {
    "Transaction": {
      "title": "Transaction",
      "description": "An income or expense transaction",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "amount": { "type": "number" },
        "type": { "type": "string", "enum": ["income", "expense"] },
        "category": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "description": { "type": "string" },
        "createdAt": { "type": "string" }
      },
      "required": ["id", "uid", "amount", "type", "category", "date", "createdAt"]
    },
    "Budget": {
      "title": "Budget",
      "description": "Monthly budget limit for a user",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "uid": { "type": "string" },
        "month": { "type": "string" },
        "limit": { "type": "number" }
      },
      "required": ["id", "uid", "month", "limit"]
    }
  },
  "firestore": {
    "transactions/{transactionId}": {
      "schema": "Transaction",
      "description": "Collection of transactions"
    },
    "budgets/{budgetId}": {
      "schema": "Budget",
      "description": "Collection of user budgets"
    }
  }
}
